import pygame
import sys
import random
import os  # Added to safely locate files on your computer

# --- Initialization & Audio Setup ---
pygame.init()
pygame.mixer.init()

WIDTH, HEIGHT = 800, 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("If Gemini (A.I) tried to make a Undertale fight... (music by me (Stunamiii))")
clock = pygame.time.Clock()

# Locate the folder where this script is saved
script_dir = os.path.dirname(os.path.abspath(__file__))
wav_path = os.path.join(script_dir, "battle_music.wav")

# Attempt to load and play the .wav file
try:
    pygame.mixer.music.load(wav_path)
    pygame.mixer.music.play(-1)  # -1 loops the track indefinitely
    print("🔊 Success! battle_music.wav loaded and playing.")
except pygame.error as e:
    print(f"❌ Pygame Audio Error: {e}")
    print("👉 Double-check that your file is named exactly 'battle_music.wav' and sits in your PyCharm sidebar folder.")

# --- Colors & Fonts ---
BLACK = (0, 0, 0)
WHITE = (255, 255, 255)
RED = (255, 0, 0)
YELLOW = (255, 255, 0)
GREEN = (0, 255, 0)

font_large = pygame.font.SysFont("courier", 32, bold=True)
font_small = pygame.font.SysFont("courier", 22, bold=True)


# --- Classes ---
class Player:
    def __init__(self):
        self.rect = pygame.Rect(0, 0, 16, 16)
        self.speed = 4
        self.hp = 20
        self.max_hp = 20

    def move(self, keys, boundary):
        if keys[pygame.K_UP] and self.rect.top > boundary.top: self.rect.y -= self.speed
        if keys[pygame.K_DOWN] and self.rect.bottom < boundary.bottom: self.rect.y += self.speed
        if keys[pygame.K_LEFT] and self.rect.left > boundary.left: self.rect.x -= self.speed
        if keys[pygame.K_RIGHT] and self.rect.right < boundary.right: self.rect.x += self.speed

    def draw(self, surface):
        pygame.draw.rect(surface, RED, self.rect)


class Enemy:
    def __init__(self):
        self.name = "A.I enemy guy"
        self.hp = 50
        self.max_hp = 50


class Bullet:
    def __init__(self, boundary):
        self.rect = pygame.Rect(random.randint(boundary.left + 10, boundary.right - 20), boundary.top - 10, 12, 12)
        self.speed_y = random.randint(4, 6)
        self.speed_x = random.choice([-2, 0, 2])

    def update(self):
        self.rect.y += self.speed_y
        self.rect.x += self.speed_x


# --- UI Helper Function ---
def draw_text_animated(text, position, visible_chars):
    substring = text[:int(visible_chars)]
    rendered = font_small.render(substring, True, WHITE)
    screen.blit(rendered, position)


# --- Main Game Loop ---
def main():
    player = Player()
    enemy = Enemy()

    state = "MENU"
    menu_options = ["FIGHT", "ACT", "ITEM", "MERCY"]
    selected_option = 0

    current_dialog = f"* {enemy.name} blocks your path code!"
    text_counter = 0.0
    text_speed = 0.5

    arena_rect = pygame.Rect(100, 250, 600, 200)
    bullets = []
    defend_timer = 0

    while True:
        screen.fill(BLACK)
        keys = pygame.key.get_pressed()

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit()
                sys.exit()

            if event.type == pygame.KEYDOWN:
                if state == "MENU":
                    if event.key == pygame.K_LEFT:
                        selected_option = (selected_option - 1) % 4
                    elif event.key == pygame.K_RIGHT:
                        selected_option = (selected_option + 1) % 4
                    elif event.key == pygame.K_z or event.key == pygame.K_RETURN:
                        if selected_option == 0:
                            damage = random.randint(12, 18)
                            enemy.hp -= damage
                            current_dialog = f"* You sliced {enemy.name} for {damage} damage!"
                        elif selected_option == 1:
                            current_dialog = f"* You check {enemy.name}.\n* ATK 10 DEF 5.\n* Smells like syntax errors."
                        elif selected_option == 2:
                            player.hp = min(player.max_hp, player.hp + 10)
                            current_dialog = "* You ate the Cinnamon Bunny. HP restored!"
                        elif selected_option == 3:
                            current_dialog = "* SPARE is yellow, but you must fight!"

                        text_counter = 0.0
                        state = "TEXT_CRAWL"

                elif state == "TEXT_CRAWL":
                    if event.key == pygame.K_z or event.key == pygame.K_RETURN:
                        if text_counter < len(current_dialog):
                            text_counter = len(current_dialog)
                        else:
                            if enemy.hp <= 0:
                                state = "VICTORY"
                            else:
                                state = "DEFEND"
                                defend_timer = 240
                                bullets.clear()
                                player.rect.center = arena_rect.center

                elif state in ["GAMEOVER", "VICTORY"]:
                    if event.key == pygame.K_r:
                        main()

                        # --- Rendering ---
        if state != "VICTORY":
            enemy_pulse = pygame.Rect(WIDTH // 2 - 40, 80 + int(random.random() * 4), 80, 80)
            pygame.draw.rect(screen, WHITE, enemy_pulse, 3)
            e_name = font_small.render(enemy.name, True, WHITE)
            screen.blit(e_name, (WIDTH // 2 - 45, 45))

        pygame.draw.rect(screen, WHITE, arena_rect, 4)

        if state == "MENU":
            text_counter = min(len(current_dialog), text_counter + text_speed)
            draw_text_animated(current_dialog, (arena_rect.left + 20, arena_rect.top + 20), text_counter)
            heart_positions = [95, 255, 415, 575]
            pygame.draw.rect(screen, RED, (heart_positions[selected_option], HEIGHT - 78, 12, 12))

        elif state == "TEXT_CRAWL":
            text_counter = min(len(current_dialog), text_counter + text_speed)
            lines = current_dialog.split('\n')
            for idx, line in enumerate(lines):
                draw_text_animated(line, (arena_rect.left + 20, arena_rect.top + 20 + (idx * 30)), text_counter)

        elif state == "DEFEND":
            player.move(keys, arena_rect)
            player.draw(screen)

            if random.random() < 0.08:
                bullets.append(Bullet(arena_rect))

            for bullet in bullets[:]:
                bullet.update()
                pygame.draw.rect(screen, WHITE, bullet.rect)

                if player.rect.colliderect(bullet.rect):
                    player.hp -= 1
                    bullets.remove(bullet)
                    if player.hp <= 0: state = "GAMEOVER"
                elif bullet.rect.top > arena_rect.bottom:
                    bullets.remove(bullet)

            defend_timer -= 1
            if defend_timer <= 0 and state != "GAMEOVER":
                current_dialog = "* The battle heats up!"
                text_counter = 0.0
                state = "MENU"

        elif state == "GAMEOVER":
            screen.fill(BLACK)
            screen.blit(font_large.render("GAME OVER", True, RED), (WIDTH // 2 - 80, HEIGHT // 2 - 40))
            screen.blit(font_small.render("Press 'R' to try again", True, WHITE), (WIDTH // 2 - 130, HEIGHT // 2 + 20))

        elif state == "VICTORY":
            screen.fill(BLACK)
            screen.blit(font_large.render("YOU WIN!", True, GREEN), (WIDTH // 2 - 70, HEIGHT // 2 - 40))
            screen.blit(font_small.render("You earned 0 EXP and 10 G.", True, WHITE),
                        (WIDTH // 2 - 150, HEIGHT // 2 + 20))
            screen.blit(font_small.render("Press 'R' to replay", True, YELLOW), (WIDTH // 2 - 110, HEIGHT // 2 + 60))

        # --- Draw Bottom Player Stats ---
        if state in ["MENU", "TEXT_CRAWL", "DEFEND"]:
            hud_text = font_small.render(f"FRISK   LV 1", True, WHITE)
            screen.blit(hud_text, (100, HEIGHT - 130))

            hp_label = font_small.render("HP", True, WHITE)
            screen.blit(hp_label, (320, HEIGHT - 130))

            pygame.draw.rect(screen, RED, (360, HEIGHT - 125, 100, 16))
            hp_pct = max(0.0, player.hp / player.max_hp)
            pygame.draw.rect(screen, YELLOW, (360, HEIGHT - 125, int(100 * hp_pct), 16))

            hp_num = font_small.render(f"{player.hp} / {player.max_hp}", True, WHITE)
            screen.blit(hp_num, (475, HEIGHT - 130))

            for i, option in enumerate(menu_options):
                btn_border = YELLOW if (i == selected_option and state == "MENU") else WHITE
                pygame.draw.rect(screen, btn_border, (120 + i * 160, HEIGHT - 90, 120, 35), 2)
                btn_text = font_small.render(option, True, btn_border)
                screen.blit(btn_text, (150 + i * 160, HEIGHT - 83))

        pygame.display.flip()
        clock.tick(60)


if __name__ == "__main__":
    main()




